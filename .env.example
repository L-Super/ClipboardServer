# 数据库配置
# SQLite（默认）
DATABASE_URL=sqlite:///clipboard.db
# MySQL（可选）
# DATABASE_URL=mysql+pymysql://user:password@localhost/clipboard_db

# JWT 配置
SECRET_KEY=secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# 时区
TZ=Asia/Shanghai

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=[%(asctime)s - %(levelname)s (%(name)s) %(filename)s:%(lineno)d] %(message)s
LOG_FILE_PATH=logs/app_log.log
LOG_MAX_BYTES=102400
LOG_BACKUP_COUNT=3
LOG_ENABLE_CONSOLE=True
LOG_ENABLE_FILE=True

# 上传配置
MAX_UPLOAD_SIZE_MB=20

# 邮件配置（SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM_EMAIL=your_email@qq.com
EMAIL_CODE_EXPIRE_MINUTES=5